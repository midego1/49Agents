#!/bin/bash
# ─── 49ctl — 49Agents Process Manager ─────────────────────────────────────
# Usage: ./49ctl <command> [options]
#
# Commands:
#   setup          Interactive setup (choose single/multi machine, port, etc.)
#   start          Start cloud server and/or agent (based on setup config)
#   stop           Stop all running processes
#   restart        Stop then start
#   status         Show running process status
#   logs [service] Tail logs (cloud, agent, or both)
#   build          Rebuild client assets + agent tarball
#   cloud-start    Start only the cloud server
#   cloud-stop     Stop only the cloud server
#   agent-start    Start only the agent
#   agent-stop     Stop only the agent
#   help           Show this help

set -euo pipefail

# ── Colors ──
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Paths ──
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
STATE_DIR="$SCRIPT_DIR/.49agents"
CLOUD_PID_FILE="$STATE_DIR/cloud.pid"
AGENT_PID_FILE="$STATE_DIR/agent.pid"
CLOUD_LOG="$STATE_DIR/cloud.log"
AGENT_LOG="$STATE_DIR/agent.log"
CONFIG_FILE="$STATE_DIR/config"

mkdir -p "$STATE_DIR"

# ── Add .49agents to .gitignore if not already there ──
if [ -f "$SCRIPT_DIR/.gitignore" ]; then
  if ! grep -qx '.49agents/' "$SCRIPT_DIR/.gitignore" 2>/dev/null; then
    echo '.49agents/' >> "$SCRIPT_DIR/.gitignore"
  fi
fi

# ── Helpers ──

# Check if a PID is alive
is_alive() {
  local pid="$1"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

# Read PID from file, verify it's alive
read_pid() {
  local pidfile="$1"
  if [ -f "$pidfile" ]; then
    local pid
    pid=$(cat "$pidfile" 2>/dev/null)
    if is_alive "$pid"; then
      echo "$pid"
      return 0
    else
      rm -f "$pidfile"
    fi
  fi
  return 1
}

# Kill process by PID file
kill_by_pidfile() {
  local pidfile="$1"
  local name="$2"
  local pid
  if pid=$(read_pid "$pidfile"); then
    echo -e "  Stopping ${name} (PID ${pid})..."
    kill "$pid" 2>/dev/null
    # Wait up to 5 seconds for graceful shutdown
    local i=0
    while [ $i -lt 50 ] && is_alive "$pid"; do
      sleep 0.1
      i=$((i + 1))
    done
    # Force kill if still alive
    if is_alive "$pid"; then
      kill -9 "$pid" 2>/dev/null
    fi
    rm -f "$pidfile"
    echo -e "  ${GREEN}${name} stopped.${NC}"
  fi
}

# Load config
load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
  # Defaults
  RUN_CLOUD="${RUN_CLOUD:-true}"
  RUN_AGENT="${RUN_AGENT:-true}"
  CLOUD_PORT="${CLOUD_PORT:-1071}"
  AGENT_CLOUD_URL="${AGENT_CLOUD_URL:-ws://localhost:$CLOUD_PORT}"
}

save_config() {
  cat > "$CONFIG_FILE" <<CONF
# 49Agents config — generated by 49ctl setup
RUN_CLOUD=$RUN_CLOUD
RUN_AGENT=$RUN_AGENT
CLOUD_PORT=$CLOUD_PORT
AGENT_CLOUD_URL=$AGENT_CLOUD_URL
CONF
}

# ── Commands ──

cmd_setup() {
  echo ""
  echo -e "${CYAN}${BOLD}49Agents — Setup${NC}"
  echo "-----------------------------"
  echo ""

  echo "How are you setting this up?"
  echo ""
  echo "  1) Single machine  — cloud + agent on this machine (default)"
  echo "  2) Multi machine   — choose what runs on this machine"
  echo ""
  read -rp "Enter choice [1/2, default: 1]: " SETUP_CHOICE
  SETUP_CHOICE="${SETUP_CHOICE:-1}"
  echo ""

  RUN_CLOUD=false
  RUN_AGENT=false
  CLOUD_PORT=1071
  AGENT_CLOUD_URL=""

  if [ "$SETUP_CHOICE" = "1" ]; then
    RUN_CLOUD=true
    RUN_AGENT=true
    read -rp "Port to run the server on [default: 1071]: " PORT_INPUT
    CLOUD_PORT="${PORT_INPUT:-1071}"
    AGENT_CLOUD_URL="ws://localhost:${CLOUD_PORT}"

  elif [ "$SETUP_CHOICE" = "2" ]; then
    echo "What should this machine run?"
    echo ""
    echo "  1) Cloud server only"
    echo "  2) Agent only"
    echo "  3) Both"
    echo ""
    read -rp "Enter choice [1/2/3]: " ROLE_CHOICE
    echo ""

    if [ "$ROLE_CHOICE" = "1" ]; then
      RUN_CLOUD=true
      read -rp "Port to run the cloud server on [default: 1071]: " PORT_INPUT
      CLOUD_PORT="${PORT_INPUT:-1071}"
    elif [ "$ROLE_CHOICE" = "2" ]; then
      RUN_AGENT=true
      read -rp "URL of the cloud server (e.g. ws://192.168.1.10:1071): " URL_INPUT
      AGENT_CLOUD_URL="${URL_INPUT:-ws://localhost:1071}"
    elif [ "$ROLE_CHOICE" = "3" ]; then
      RUN_CLOUD=true
      RUN_AGENT=true
      read -rp "Port to run the cloud server on [default: 1071]: " PORT_INPUT
      CLOUD_PORT="${PORT_INPUT:-1071}"
      AGENT_CLOUD_URL="ws://localhost:${CLOUD_PORT}"
    else
      echo "Invalid choice."
      exit 1
    fi
  else
    echo "Invalid choice."
    exit 1
  fi

  save_config

  # Check dependencies if agent will run
  if [ "$RUN_AGENT" = "true" ]; then
    check_agent_deps
  fi

  # Install npm deps + build
  cmd_build

  echo ""
  echo -e "${GREEN}Setup complete.${NC} Run ${BOLD}./49ctl start${NC} to launch."
  echo ""
}

check_agent_deps() {
  local missing=false
  if ! command -v tmux &>/dev/null; then
    echo -e "${RED}tmux is not installed.${NC}"
    missing=true
  fi
  if ! command -v ttyd &>/dev/null; then
    echo -e "${RED}ttyd is not installed.${NC}"
    missing=true
  fi
  if [ "$missing" = "true" ]; then
    echo ""
    echo "The agent requires tmux and ttyd. Install them:"
    if [ "$(uname)" = "Darwin" ]; then
      echo "  brew install tmux ttyd"
    else
      echo "  sudo apt-get install -y tmux  # or your distro's package manager"
      echo "  # ttyd: https://github.com/tsl0922/ttyd/releases"
    fi
    echo ""
    read -rp "Continue anyway? [y/N]: " CONT
    if [[ ! "$CONT" =~ ^[Yy]$ ]]; then
      exit 1
    fi
  fi
}

cmd_build() {
  echo -e "${YELLOW}Installing dependencies...${NC}"
  (cd "$SCRIPT_DIR/cloud" && npm install --silent 2>&1)
  (cd "$SCRIPT_DIR/agent" && npm install --silent 2>&1)
  echo -e "${YELLOW}Building client assets...${NC}"
  (cd "$SCRIPT_DIR/cloud" && npm run build --silent 2>&1)
  echo -e "${YELLOW}Building agent tarball...${NC}"
  mkdir -p "$SCRIPT_DIR/cloud/dl"
  tar czf "$SCRIPT_DIR/cloud/dl/49-agent.tar.gz" -C "$SCRIPT_DIR" agent/
  echo -e "${GREEN}Build complete.${NC}"
}

cmd_start() {
  load_config

  # Check if config exists
  if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${YELLOW}No config found. Running setup first...${NC}"
    cmd_setup
    return
  fi

  local started=false

  if [ "$RUN_CLOUD" = "true" ]; then
    start_cloud
    started=true
  fi

  if [ "$RUN_AGENT" = "true" ]; then
    # Give cloud a moment to start if we're running both
    if [ "$RUN_CLOUD" = "true" ]; then
      sleep 2
    fi
    start_agent
    started=true
  fi

  if [ "$started" = "false" ]; then
    echo -e "${YELLOW}Nothing configured to start. Run ./49ctl setup${NC}"
    return
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Running!${NC}"
  if [ "$RUN_CLOUD" = "true" ]; then
    local cpid
    cpid=$(read_pid "$CLOUD_PID_FILE" 2>/dev/null || echo "?")
    echo -e "  Cloud  ${CYAN}http://localhost:${CLOUD_PORT}${NC}  ${DIM}(PID ${cpid})${NC}"
  fi
  if [ "$RUN_AGENT" = "true" ]; then
    local apid
    apid=$(read_pid "$AGENT_PID_FILE" 2>/dev/null || echo "?")
    echo -e "  Agent  ${CYAN}${AGENT_CLOUD_URL}${NC}  ${DIM}(PID ${apid})${NC}"
  fi
  echo ""
  echo -e "Use ${BOLD}./49ctl status${NC} to check, ${BOLD}./49ctl logs${NC} to tail, ${BOLD}./49ctl stop${NC} to stop."
  echo ""
}

start_cloud() {
  if pid=$(read_pid "$CLOUD_PID_FILE" 2>/dev/null); then
    echo -e "  Cloud server already running ${DIM}(PID ${pid})${NC}"
    return
  fi

  # Kill any orphan on the port
  local orphan
  orphan=$(lsof -ti:"$CLOUD_PORT" -sTCP:LISTEN 2>/dev/null || true)
  if [ -n "$orphan" ]; then
    echo -e "  ${YELLOW}Killing orphan process on port ${CLOUD_PORT} (PID ${orphan})${NC}"
    kill -9 $orphan 2>/dev/null || true
    sleep 1
  fi

  echo -e "  Starting cloud server on port ${CLOUD_PORT}..."
  PORT="$CLOUD_PORT" nohup node "$SCRIPT_DIR/cloud/src/index.js" >> "$CLOUD_LOG" 2>&1 &
  local pid=$!
  echo "$pid" > "$CLOUD_PID_FILE"

  # Wait briefly and verify it started
  sleep 2
  if is_alive "$pid"; then
    echo -e "  ${GREEN}Cloud server started${NC} ${DIM}(PID ${pid})${NC}"
  else
    echo -e "  ${RED}Cloud server failed to start. Check logs:${NC}"
    echo -e "  ${DIM}tail -20 $CLOUD_LOG${NC}"
    rm -f "$CLOUD_PID_FILE"
  fi
}

start_agent() {
  if pid=$(read_pid "$AGENT_PID_FILE" 2>/dev/null); then
    echo -e "  Agent already running ${DIM}(PID ${pid})${NC}"
    return
  fi

  # Check for rogue agent processes not tracked by 49ctl
  local rogues
  rogues=$(pgrep -f "49-agent.js start" 2>/dev/null || true)
  if [ -n "$rogues" ]; then
    echo -e "  ${YELLOW}Found existing agent process(es) not started by 49ctl: ${rogues}${NC}"
    echo -e "  ${YELLOW}Killing them to avoid duplicate connections...${NC}"
    echo "$rogues" | xargs kill 2>/dev/null || true
    sleep 1
  fi

  echo -e "  Starting agent (connecting to ${AGENT_CLOUD_URL})..."
  TC_CLOUD_URL="$AGENT_CLOUD_URL" nohup node "$SCRIPT_DIR/agent/bin/49-agent.js" start >> "$AGENT_LOG" 2>&1 &
  local pid=$!
  echo "$pid" > "$AGENT_PID_FILE"

  sleep 2
  if is_alive "$pid"; then
    echo -e "  ${GREEN}Agent started${NC} ${DIM}(PID ${pid})${NC}"
  else
    echo -e "  ${RED}Agent failed to start. Check logs:${NC}"
    echo -e "  ${DIM}tail -20 $AGENT_LOG${NC}"
    rm -f "$AGENT_PID_FILE"
  fi
}

cmd_stop() {
  echo ""
  local stopped=false

  if [ -f "$CLOUD_PID_FILE" ]; then
    kill_by_pidfile "$CLOUD_PID_FILE" "Cloud server"
    stopped=true
  fi

  if [ -f "$AGENT_PID_FILE" ]; then
    kill_by_pidfile "$AGENT_PID_FILE" "Agent"
    stopped=true
  fi

  # Also kill any orphans on the configured port
  load_config
  local orphan
  orphan=$(lsof -ti:"$CLOUD_PORT" -sTCP:LISTEN 2>/dev/null || true)
  if [ -n "$orphan" ]; then
    echo -e "  Killing orphan on port ${CLOUD_PORT} (PID ${orphan})"
    kill -9 $orphan 2>/dev/null || true
    stopped=true
  fi

  if [ "$stopped" = "false" ]; then
    echo -e "  Nothing running."
  fi
  echo ""
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_status() {
  load_config
  echo ""
  echo -e "${BOLD}49Agents Status${NC}"
  echo "-----------------------------"

  # Cloud
  if [ "$RUN_CLOUD" = "true" ]; then
    local cpid
    if cpid=$(read_pid "$CLOUD_PID_FILE" 2>/dev/null); then
      echo -e "  Cloud   ${GREEN}running${NC}  PID ${cpid}  http://localhost:${CLOUD_PORT}"
    else
      echo -e "  Cloud   ${RED}stopped${NC}"
    fi
  else
    echo -e "  Cloud   ${DIM}not configured${NC}"
  fi

  # Agent
  if [ "$RUN_AGENT" = "true" ]; then
    local apid
    if apid=$(read_pid "$AGENT_PID_FILE" 2>/dev/null); then
      echo -e "  Agent   ${GREEN}running${NC}  PID ${apid}  ${AGENT_CLOUD_URL}"
    else
      echo -e "  Agent   ${RED}stopped${NC}"
    fi
  else
    echo -e "  Agent   ${DIM}not configured${NC}"
  fi

  echo ""
}

cmd_logs() {
  local service="${1:-all}"

  case "$service" in
    cloud)
      echo -e "${DIM}── Cloud logs ($CLOUD_LOG) ──${NC}"
      tail -f "$CLOUD_LOG"
      ;;
    agent)
      echo -e "${DIM}── Agent logs ($AGENT_LOG) ──${NC}"
      tail -f "$AGENT_LOG"
      ;;
    all|both)
      tail -f "$CLOUD_LOG" "$AGENT_LOG"
      ;;
    *)
      echo "Usage: ./49ctl logs [cloud|agent|all]"
      ;;
  esac
}

cmd_cloud_start() {
  load_config
  RUN_CLOUD=true
  start_cloud
}

cmd_cloud_stop() {
  kill_by_pidfile "$CLOUD_PID_FILE" "Cloud server"
  load_config
  local orphan
  orphan=$(lsof -ti:"$CLOUD_PORT" -sTCP:LISTEN 2>/dev/null || true)
  if [ -n "$orphan" ]; then
    echo -e "  Killing orphan on port ${CLOUD_PORT} (PID ${orphan})"
    kill -9 $orphan 2>/dev/null || true
  fi
}

cmd_agent_start() {
  load_config
  RUN_AGENT=true
  start_agent
}

cmd_agent_stop() {
  kill_by_pidfile "$AGENT_PID_FILE" "Agent"
}

# ── Session / State Commands ──

AGENT_CONFIG_DIR="$HOME/.49agents"
AGENT_TOKEN_FILE="$AGENT_CONFIG_DIR/agent.json"
AGENT_TERMINALS_FILE="$AGENT_CONFIG_DIR/terminals.json"
CLOUD_DB_FILE="$SCRIPT_DIR/cloud/data/tc.db"

cmd_session() {
  echo ""
  echo -e "${BOLD}49Agents Session State${NC}"
  echo "-----------------------------"
  echo ""

  # Agent auth token
  echo -e "${BOLD}Agent Identity${NC}  ${DIM}($AGENT_TOKEN_FILE)${NC}"
  if [ -f "$AGENT_TOKEN_FILE" ]; then
    local saved_at
    saved_at=$(node -e "try{console.log(JSON.parse(require('fs').readFileSync('$AGENT_TOKEN_FILE','utf8')).savedAt)}catch{console.log('unknown')}" 2>/dev/null)
    echo -e "  Token:    ${GREEN}present${NC}"
    echo -e "  Saved at: ${saved_at}"
    echo -e "  ${DIM}This token is how the agent authenticates with the cloud server.${NC}"
    echo -e "  ${DIM}It persists across restarts so you don't need to re-pair each time.${NC}"
  else
    echo -e "  Token:    ${RED}not found${NC}"
    echo -e "  ${DIM}The agent has no saved token. It will need to pair on next start.${NC}"
  fi
  echo ""

  # Agent terminal state
  echo -e "${BOLD}Terminal State${NC}  ${DIM}($AGENT_TERMINALS_FILE)${NC}"
  if [ -f "$AGENT_TERMINALS_FILE" ]; then
    local count
    count=$(node -e "try{const d=JSON.parse(require('fs').readFileSync('$AGENT_TERMINALS_FILE','utf8'));const t=d.terminals||d;console.log(Array.isArray(t)?t.length:Object.keys(t).length)}catch{console.log(0)}" 2>/dev/null)
    echo -e "  Saved in tracking file: ${CYAN}${count}${NC}"
    echo -e "  ${DIM}The agent's record of tmux sessions it manages. Persists across${NC}"
    echo -e "  ${DIM}restarts so panes reappear in the browser without re-creating them.${NC}"
  else
    echo -e "  Saved in tracking file: ${DIM}none${NC}"
  fi
  echo ""

  # tmux sessions (moved up, next to terminal state for clarity)
  echo -e "${BOLD}Live tmux Sessions${NC}"
  if command -v tmux &>/dev/null; then
    local tmux_count=0
    local tmux_sessions
    tmux_sessions=$(tmux list-sessions 2>/dev/null || true)
    if [ -n "$tmux_sessions" ]; then
      tmux_count=$(echo "$tmux_sessions" | wc -l | tr -d ' ')
      echo -e "  Running: ${CYAN}${tmux_count}${NC}"
      echo "$tmux_sessions" | while IFS= read -r line; do
        echo -e "    ${DIM}${line}${NC}"
      done
      echo -e "  ${DIM}These are real OS processes. The agent discovers them on startup${NC}"
      echo -e "  ${DIM}even if they aren't in the tracking file.${NC}"
    else
      echo -e "  Running: ${DIM}0${NC}"
    fi
  else
    echo -e "  ${DIM}tmux not installed${NC}"
  fi
  echo ""

  # Cloud database
  echo -e "${BOLD}Cloud Database${NC}  ${DIM}($CLOUD_DB_FILE)${NC}"
  if [ -f "$CLOUD_DB_FILE" ]; then
    local db_size
    db_size=$(du -h "$CLOUD_DB_FILE" | cut -f1)
    echo -e "  Database: ${GREEN}present${NC} (${db_size})"

    # Query some stats
    local user_count agent_count pane_count note_count
    user_count=$(sqlite3 "$CLOUD_DB_FILE" "SELECT COUNT(*) FROM users;" 2>/dev/null || echo "?")
    agent_count=$(sqlite3 "$CLOUD_DB_FILE" "SELECT COUNT(*) FROM agents;" 2>/dev/null || echo "?")
    pane_count=$(sqlite3 "$CLOUD_DB_FILE" "SELECT COUNT(*) FROM pane_layouts;" 2>/dev/null || echo "?")
    note_count=$(sqlite3 "$CLOUD_DB_FILE" "SELECT COUNT(*) FROM notes;" 2>/dev/null || echo "?")
    echo -e "  Users:  ${user_count}   Agents: ${agent_count}   Panes: ${pane_count}   Notes: ${note_count}"
    echo -e "  ${DIM}Stores users, agent registrations, pane layouts, notes, and preferences.${NC}"
  else
    echo -e "  Database: ${DIM}not created yet${NC} (created on first server start)"
  fi
  echo ""

  # 49ctl config
  echo -e "${BOLD}49ctl Config${NC}  ${DIM}($CONFIG_FILE)${NC}"
  if [ -f "$CONFIG_FILE" ]; then
    load_config
    echo -e "  Cloud:    ${RUN_CLOUD}  (port ${CLOUD_PORT})"
    echo -e "  Agent:    ${RUN_AGENT}  (relay ${AGENT_CLOUD_URL})"
  else
    echo -e "  ${DIM}Not configured yet. Run ./49ctl setup${NC}"
  fi
  echo ""

  # Log files
  echo -e "${BOLD}Log Files${NC}"
  if [ -f "$CLOUD_LOG" ]; then
    local cloud_log_size
    cloud_log_size=$(du -h "$CLOUD_LOG" | cut -f1)
    echo -e "  Cloud log: ${cloud_log_size}  ${DIM}($CLOUD_LOG)${NC}"
  else
    echo -e "  Cloud log: ${DIM}not created${NC}"
  fi
  if [ -f "$AGENT_LOG" ]; then
    local agent_log_size
    agent_log_size=$(du -h "$AGENT_LOG" | cut -f1)
    echo -e "  Agent log: ${agent_log_size}  ${DIM}($AGENT_LOG)${NC}"
  else
    echo -e "  Agent log: ${DIM}not created${NC}"
  fi
  echo ""
}

cmd_reset_agent() {
  echo ""
  echo -e "${BOLD}Reset Agent Identity${NC}"
  echo ""
  echo "This will:"
  echo "  1. Stop the agent if running"
  echo "  2. Delete the auth token ($AGENT_TOKEN_FILE)"
  echo "  3. The agent will need to re-pair with the cloud on next start"
  echo ""
  read -rp "Continue? [y/N]: " CONFIRM
  if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    return
  fi

  # Stop agent
  if [ -f "$AGENT_PID_FILE" ]; then
    kill_by_pidfile "$AGENT_PID_FILE" "Agent"
  fi

  # Delete token
  if [ -f "$AGENT_TOKEN_FILE" ]; then
    rm -f "$AGENT_TOKEN_FILE"
    echo -e "  ${GREEN}Agent token deleted.${NC}"
  else
    echo -e "  No token file found."
  fi
  echo ""
}

cmd_reset_terminals() {
  echo ""
  echo -e "${BOLD}Reset Terminal State${NC}"
  echo ""
  echo "This will:"
  echo "  1. Delete the terminal tracking file ($AGENT_TERMINALS_FILE)"
  echo "  2. The agent will re-discover tmux sessions on next start"
  echo "  3. Existing tmux sessions are NOT killed (just forgotten)"
  echo ""
  read -rp "Continue? [y/N]: " CONFIRM
  if [[ ! "$CONFIRM" =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    return
  fi

  if [ -f "$AGENT_TERMINALS_FILE" ]; then
    rm -f "$AGENT_TERMINALS_FILE"
    echo -e "  ${GREEN}Terminal state cleared.${NC}"
  else
    echo -e "  No terminal state file found."
  fi
  echo ""
}

cmd_reset_db() {
  echo ""
  echo -e "${BOLD}Reset Cloud Database${NC}"
  echo ""
  echo -e "${RED}WARNING: This will delete ALL cloud data:${NC}"
  echo "  - User accounts and preferences"
  echo "  - Agent registrations"
  echo "  - Pane layouts and positions"
  echo "  - Notes"
  echo "  - Event history"
  echo ""
  echo "The database will be recreated fresh on next server start."
  echo ""
  read -rp "Type 'reset' to confirm: " CONFIRM
  if [ "$CONFIRM" != "reset" ]; then
    echo "Cancelled."
    return
  fi

  # Stop cloud server first
  if [ -f "$CLOUD_PID_FILE" ]; then
    kill_by_pidfile "$CLOUD_PID_FILE" "Cloud server"
  fi

  if [ -f "$CLOUD_DB_FILE" ]; then
    rm -f "$CLOUD_DB_FILE" "${CLOUD_DB_FILE}-wal" "${CLOUD_DB_FILE}-shm"
    echo -e "  ${GREEN}Database deleted.${NC}"
  else
    echo -e "  No database found."
  fi
  echo ""
}

cmd_reset_all() {
  echo ""
  echo -e "${BOLD}Full Reset${NC}"
  echo ""
  echo -e "${RED}WARNING: This will delete ALL persistent state:${NC}"
  echo "  - Agent auth token (will need to re-pair)"
  echo "  - Terminal tracking (agent re-discovers on start)"
  echo "  - Cloud database (users, layouts, notes — all gone)"
  echo "  - Log files"
  echo "  - 49ctl config (will need to re-run setup)"
  echo ""
  echo "tmux sessions are NOT killed."
  echo ""
  read -rp "Type 'reset-all' to confirm: " CONFIRM
  if [ "$CONFIRM" != "reset-all" ]; then
    echo "Cancelled."
    return
  fi

  # Stop everything first
  cmd_stop

  rm -f "$AGENT_TOKEN_FILE"
  rm -f "$AGENT_TERMINALS_FILE"
  rm -f "$CLOUD_DB_FILE" "${CLOUD_DB_FILE}-wal" "${CLOUD_DB_FILE}-shm"
  rm -f "$CLOUD_LOG" "$AGENT_LOG"
  rm -f "$CONFIG_FILE"

  echo ""
  echo -e "  ${GREEN}All state cleared.${NC}"
  echo -e "  Run ${BOLD}./49ctl setup${NC} to start fresh."
  echo ""
}

cmd_clear_logs() {
  echo ""
  > "$CLOUD_LOG" 2>/dev/null && echo -e "  ${GREEN}Cloud log cleared${NC}" || true
  > "$AGENT_LOG" 2>/dev/null && echo -e "  ${GREEN}Agent log cleared${NC}" || true
  echo ""
}

# ── Dev Mode ──
# Runs cloud + agent on a custom port with ISOLATED state.
# Does NOT touch ~/.49agents/ or the main cloud/data/ database.
# Safe to run alongside a production instance on port 1071.

cmd_dev() {
  local port="${1:-1075}"
  local dev_dir="$STATE_DIR/dev-${port}"
  local dev_db="$dev_dir/tc.db"
  local dev_agent_config="$dev_dir/agent-config"
  local dev_cloud_log="$dev_dir/cloud.log"
  local dev_agent_log="$dev_dir/agent.log"
  local dev_cloud_pid="$dev_dir/cloud.pid"
  local dev_agent_pid="$dev_dir/agent.pid"

  mkdir -p "$dev_dir" "$dev_agent_config"

  echo ""
  echo -e "${CYAN}${BOLD}49Agents Dev Mode${NC} — port ${port}"
  echo -e "${DIM}Isolated state in ${dev_dir}${NC}"
  echo "-----------------------------"

  # Kill any existing dev processes for this port
  if [ -f "$dev_cloud_pid" ]; then
    local old_pid
    old_pid=$(cat "$dev_cloud_pid" 2>/dev/null)
    if is_alive "$old_pid"; then
      echo -e "  ${YELLOW}Stopping previous dev cloud (PID ${old_pid})${NC}"
      kill "$old_pid" 2>/dev/null
      sleep 1
    fi
    rm -f "$dev_cloud_pid"
  fi
  if [ -f "$dev_agent_pid" ]; then
    local old_pid
    old_pid=$(cat "$dev_agent_pid" 2>/dev/null)
    if is_alive "$old_pid"; then
      echo -e "  ${YELLOW}Stopping previous dev agent (PID ${old_pid})${NC}"
      kill "$old_pid" 2>/dev/null
      sleep 1
    fi
    rm -f "$dev_agent_pid"
  fi

  # Also kill any listener on the port
  local orphan
  orphan=$(lsof -ti:"$port" -sTCP:LISTEN 2>/dev/null || true)
  if [ -n "$orphan" ]; then
    echo -e "  ${YELLOW}Killing orphan on port ${port} (PID ${orphan})${NC}"
    kill -9 $orphan 2>/dev/null || true
    sleep 1
  fi

  # Build assets if needed
  if [ ! -f "$SCRIPT_DIR/cloud/public/app.min.js" ]; then
    echo -e "  ${YELLOW}Building client assets...${NC}"
    (cd "$SCRIPT_DIR/cloud" && npm run build --silent 2>&1)
  fi
  if [ ! -f "$SCRIPT_DIR/cloud/dl/49-agent.tar.gz" ]; then
    echo -e "  ${YELLOW}Building agent tarball...${NC}"
    mkdir -p "$SCRIPT_DIR/cloud/dl"
    tar czf "$SCRIPT_DIR/cloud/dl/49-agent.tar.gz" -C "$SCRIPT_DIR" agent/
  fi

  # Start cloud server with isolated database
  echo -e "  Starting cloud server on port ${port}..."
  PORT="$port" DATABASE_PATH="$dev_db" nohup node "$SCRIPT_DIR/cloud/src/index.js" >> "$dev_cloud_log" 2>&1 &
  local cloud_pid=$!
  echo "$cloud_pid" > "$dev_cloud_pid"
  sleep 2

  if ! is_alive "$cloud_pid"; then
    echo -e "  ${RED}Cloud server failed to start. Check: tail $dev_cloud_log${NC}"
    return 1
  fi
  echo -e "  ${GREEN}Cloud started${NC} ${DIM}(PID ${cloud_pid})${NC}"

  # Start agent with isolated config directory (separate token + terminal state)
  echo -e "  Starting agent (isolated config: ${dev_agent_config})..."
  TC_CLOUD_URL="ws://localhost:${port}" TC_CONFIG_DIR="$dev_agent_config" \
    nohup node "$SCRIPT_DIR/agent/bin/49-agent.js" start >> "$dev_agent_log" 2>&1 &
  local agent_pid=$!
  echo "$agent_pid" > "$dev_agent_pid"
  sleep 2

  if ! is_alive "$agent_pid"; then
    echo -e "  ${RED}Agent failed to start. Check: tail $dev_agent_log${NC}"
    echo -e "  ${DIM}Cloud is still running — use the browser without an agent, or use ?dev=true${NC}"
  else
    echo -e "  ${GREEN}Agent started${NC} ${DIM}(PID ${agent_pid})${NC}"
  fi

  echo ""
  echo -e "${GREEN}${BOLD}Dev instance running!${NC}"
  echo -e "  URL:     ${CYAN}http://localhost:${port}${NC}"
  echo -e "  DevPanel: ${CYAN}http://localhost:${port}?dev=true${NC}"
  echo -e "  Logs:    ${DIM}tail -f $dev_cloud_log $dev_agent_log${NC}"
  echo -e "  State:   ${DIM}$dev_dir${NC}"
  echo ""
  echo -e "  ${DIM}This instance is fully isolated from your main install.${NC}"
  echo -e "  ${DIM}Stop with: ./49ctl dev-stop ${port}${NC}"
  echo ""
}

cmd_dev_stop() {
  local port="${1:-1075}"
  local dev_dir="$STATE_DIR/dev-${port}"
  local dev_cloud_pid="$dev_dir/cloud.pid"
  local dev_agent_pid="$dev_dir/agent.pid"

  echo ""
  if [ -f "$dev_cloud_pid" ]; then
    kill_by_pidfile "$dev_cloud_pid" "Dev cloud (port ${port})"
  fi
  if [ -f "$dev_agent_pid" ]; then
    kill_by_pidfile "$dev_agent_pid" "Dev agent (port ${port})"
  fi

  local orphan
  orphan=$(lsof -ti:"$port" -sTCP:LISTEN 2>/dev/null || true)
  if [ -n "$orphan" ]; then
    echo -e "  Killing orphan on port ${port} (PID ${orphan})"
    kill -9 $orphan 2>/dev/null || true
  fi

  echo -e "  ${GREEN}Dev instance on port ${port} stopped.${NC}"
  echo ""
}

cmd_help() {
  echo ""
  echo -e "${BOLD}49ctl${NC} — 49Agents Process Manager"
  echo ""
  echo "Usage: ./49ctl <command> [options]"
  echo ""
  echo -e "${BOLD}Process Management:${NC}"
  echo "  setup          Interactive setup (port, single/multi machine)"
  echo "  start          Start services (based on setup config)"
  echo "  stop           Stop all running services"
  echo "  restart        Stop then start"
  echo "  status         Show running process status"
  echo "  logs [service] Tail logs (cloud, agent, or all)"
  echo "  build          Rebuild client assets + agent tarball"
  echo ""
  echo -e "${BOLD}Individual Services:${NC}"
  echo "  cloud-start    Start only the cloud server"
  echo "  cloud-stop     Stop only the cloud server"
  echo "  agent-start    Start only the agent"
  echo "  agent-stop     Stop only the agent"
  echo ""
  echo -e "${BOLD}Development:${NC}"
  echo "  dev [port]     Start isolated dev instance (default: 1075)"
  echo "  dev-stop [port]  Stop dev instance"
  echo ""
  echo -e "${BOLD}Session & State:${NC}"
  echo "  session        Show all persistent state (tokens, DB, terminals, config)"
  echo "  reset-agent    Delete agent auth token (forces re-pairing)"
  echo "  reset-terminals  Clear terminal tracking (agent re-discovers on start)"
  echo "  reset-db       Delete cloud database (users, layouts, notes)"
  echo "  reset-all      Delete ALL persistent state (full fresh start)"
  echo "  clear-logs     Truncate log files"
  echo ""
  echo "  help           Show this help"
  echo ""
  echo "First time? Run: ./49ctl setup"
  echo ""
}

# ── Main ──
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  setup)           cmd_setup ;;
  start)           cmd_start ;;
  stop)            cmd_stop ;;
  restart)         cmd_restart ;;
  status)          cmd_status ;;
  logs)            cmd_logs "$@" ;;
  build)           cmd_build ;;
  cloud-start)     cmd_cloud_start ;;
  cloud-stop)      cmd_cloud_stop ;;
  agent-start)     cmd_agent_start ;;
  agent-stop)      cmd_agent_stop ;;
  dev)             cmd_dev "$@" ;;
  dev-stop)        cmd_dev_stop "$@" ;;
  session)         cmd_session ;;
  reset-agent)     cmd_reset_agent ;;
  reset-terminals) cmd_reset_terminals ;;
  reset-db)        cmd_reset_db ;;
  reset-all)       cmd_reset_all ;;
  clear-logs)      cmd_clear_logs ;;
  help|--help|-h)  cmd_help ;;
  *)
    echo -e "${RED}Unknown command: ${COMMAND}${NC}"
    cmd_help
    exit 1
    ;;
esac

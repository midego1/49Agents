{
  "name": "49agents-desktop",
  "version": "0.1.0",
  "description": "49Agents desktop app for macOS",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "prestart": "cd ../cloud && npm install --silent && cd ../agent && npm install --silent",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.49agents.desktop",
    "productName": "49Agents",
    "icon": "assets/icon.icns",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../cloud",
        "to": "cloud",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!node_modules/.package-lock.json",
          "!**/*.map",
          "!src-client/**",
          "!data/**"
        ]
      },
      {
        "from": "../agent",
        "to": "agent",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!node_modules/.package-lock.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "49Agents"
    },
    "publish": {
      "provider": "github",
      "owner": "49Agents",
      "repo": "49Agents"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0"
  }
}
